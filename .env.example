# Copy this file to ".env" and fill in your real values. Never share your token or commit .env.

# From the Discord Developer Portal > your application > Bot > Token
DISCORD_TOKEN=

# From the Discord Developer Portal > your application > General Information > Application ID
CLIENT_ID=

# Optional: your server (guild) ID. Right-click your server icon > Copy Server ID
# (needs Developer Mode enabled in Discord > Settings > Advanced).
# Set this while testing so commands appear instantly. Remove it for global commands.
GUILD_ID=

# Optional but strongly recommended on Render's free tier: persists
# events.json/comps.json to Upstash Redis (REST API) instead of local disk,
# which is wiped on every redeploy/restart there.
# Create a free database at https://console.upstash.com, then copy these
# from its "REST API" section. If left blank, the bot falls back to local
# JSON files (fine for local dev, NOT fine for Render free tier).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Website login (Discord OAuth) ──────────────────────────────────────
# Reuses the SAME Discord Application as the bot (CLIENT_ID above).
# From the Discord Developer Portal > your application > OAuth2 > Client Secret.
DISCORD_CLIENT_SECRET=

# Discord Developer Portal > your application > OAuth2 > Redirects.
# Add exactly: <PUBLIC_URL>/auth/callback
# GUILD_ID above is now REQUIRED (not just for testing) — it's the server
# the site checks your roles against.
PUBLIC_URL=

# Any long random string, e.g. `openssl rand -hex 32`. Used to sign the
# website's login session cookie. Changing this logs everyone out.
SESSION_SECRET=

# Right-click each role in your Discord server > Copy Role ID
# (Developer Mode must be on: Discord > Settings > Advanced).
# Admin can do everything Officer can, plus edit the home page.
OFFICER_ROLE_ID=
ADMIN_ROLE_ID=
